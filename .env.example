OPENAI_API_KEY=

# Realtime transcription models.
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_REALTIME_WHISPER_MODEL=gpt-realtime-whisper
OPENAI_RECOVERY_TRANSCRIPTION_MODEL=gpt-4o-transcribe

# Text model settings for bilingual phrase cards.
OPENAI_BILINGUAL_MODEL=gpt-5.6-luna
OPENAI_BILINGUAL_REASONING_EFFORT=none

# Fast Russian translation shown beneath completed transcript turns.
OPENAI_TRANSLATION_MODEL=gpt-5-nano
OPENAI_TRANSLATION_REASONING_EFFORT=minimal

# Optional continuous Russian subtitle sidecar.
OPENAI_REALTIME_TRANSLATION_MODEL=gpt-realtime-translate
OPENAI_REALTIME_TRANSLATION_LANGUAGE=ru

# Model evaluation settings.
ECHOGUIDE_EVAL_MODELS=gpt-5.4-mini,gpt-5.6-luna,gpt-5.6-terra,gpt-5.6-sol
ECHOGUIDE_EVAL_JUDGE_MODEL=gpt-5.5
ECHOGUIDE_EVAL_JUDGE_REASONING_EFFORT=low
