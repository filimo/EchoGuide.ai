{
  "name": "echoguide-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:cert": "./scripts/create-dev-cert.sh",
    "build": "tsc --noEmit && vite build",
    "eval:models": "node scripts/eval-bilingual-models.ts",
